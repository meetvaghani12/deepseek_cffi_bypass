# Login credentials (use a test account you own and are authorized to use)
DEEPSEEK_EMAIL=your_email@example.com
DEEPSEEK_PASSWORD=your_password_here

# Official API key (required for tool calling with opencode)
# Get your key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Timeouts
BROWSER_LAUNCH_TIMEOUT=30
CHALLENGE_TIMEOUT=120
LOGIN_TIMEOUT=60
API_REQUEST_TIMEOUT=30
COOKIE_REFRESH_MARGIN=120
